RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
FROM_EMAIL=narocila@tvojadomena.si
DB_PATH=narocila.db
PORT=5000
# Domena za Caddy auto-HTTPS (na serverju npr. alerti.tvojadomena.si)
DOMAIN=localhost

# Admin email za alerte in dnevni povzetek
ADMIN_EMAIL=

# S3-kompatibilen storage za nočne backupe (Hetzner Object Storage / Backblaze B2)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-central-1
BACKUP_RETENTION_DAYS=30

# AI matching (Faza 3) — Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MATCH_PRAG_GLAVNI=0.7
MATCH_PRAG_MORDA=0.5
MATCH_BATCH=15
MATCH_MAX_NA_ZAGON=2000

# Časovna cona za urnik pošiljanja
TZ=Europe/Ljubljana
